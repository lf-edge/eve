From f2a9abed21a04d7f0a2a9933d5872e49fe128e08 Mon Sep 17 00:00:00 2001
From: Mikhail Malyshev <mike.malyshev@gmail.com>
Date: Wed, 6 May 2026 09:56:18 +0000
Subject: [PATCH] vfio/igd: dump host iGPU OpRegion to per-domain file
 (diagnostic)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Add a passive diagnostic dump of the host iGPU's OpRegion to a
per-domain file at /run/hypervisor/kvm/<qemu -name>/igd-opregion.bin
during the iGPU vfio probe.

Why:  OpRegion (which carries the VBT — Video BIOS Table — among
other host-specific structures) is one of the few pieces of
host-specific state QEMU forwards to the guest unchanged via
x-igd-opregion=on.  When iGPU passthrough misbehaves on one host
but not another, it helps to be able to diff VBT bytes between
hosts without a guest-side capture.

How:  uses VFIO_REGION_SUBTYPE_INTEL_IGD_OPREGION via
vfio_get_dev_region_info() and a pread() on the device fd.  No BAR
access, no PCI_COMMAND bits required, no device side effects.
Errors are logged and ignored — the dump never blocks vfio probe.

Logs:
  IGD: OpRegion dumped to <path> (NN bytes, magic="...")
  IGD: OpRegion region not available (vm_name=<name>)
  IGD: OpRegion pread short read: ...

Signed-off-by: Mikhail Malyshev <mike.malyshev@gmail.com>
---
 hw/vfio/igd.c | 57 +++++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 57 insertions(+)

diff --git a/tools/qemu-xen/hw/vfio/igd.c b/tools/qemu-xen/hw/vfio/igd.c
index 9ad1ad0717..fae1606e1d 100644
--- a/tools/qemu-xen/hw/vfio/igd.c
+++ b/tools/qemu-xen/hw/vfio/igd.c
@@ -16,6 +16,7 @@
 #include "qapi/error.h"
 #include "hw/hw.h"
 #include "hw/nvram/fw_cfg.h"
+#include "sysemu/sysemu.h"
 #include "pci.h"
 #include "trace.h"
 
@@ -581,6 +582,62 @@ void vfio_probe_igd_bar4_quirk(VFIOPCIDevice *vdev, int nr)
     pci_set_long(vdev->pdev.wmask + IGD_GMCH, 0);
     pci_set_long(vdev->emulated_config_bits + IGD_GMCH, ~0);
 
+    /*
+     * Diagnostic: dump the host iGPU's OpRegion to a per-domain file
+     * so the VBT contents can be inspected from outside the guest.
+     * OpRegion is one of the few pieces of host-specific state QEMU
+     * forwards to the guest unchanged via x-igd-opregion=on, so when
+     * scanout misbehaves it helps to be able to compare VBT bytes
+     * across hosts without a guest-side capture.
+     *
+     * Path: /run/hypervisor/kvm/<qemu -name>/igd-opregion.bin
+     *
+     * Passive — uses VFIO_REGION_SUBTYPE_INTEL_IGD_OPREGION via
+     * vfio_get_dev_region_info() and a pread() on the device fd; no
+     * BAR access, no PCI_COMMAND bits required, no device side
+     * effects.  Errors are logged and ignored.
+     */
+    {
+        g_autofree struct vfio_region_info *op = NULL;
+        const char *vm_name = qemu_get_vm_name();
+        if (vm_name && vfio_get_dev_region_info(&vdev->vbasedev,
+                VFIO_REGION_TYPE_PCI_VENDOR_TYPE | PCI_VENDOR_ID_INTEL,
+                VFIO_REGION_SUBTYPE_INTEL_IGD_OPREGION, &op) == 0) {
+            g_autofree void *buf = g_malloc(op->size);
+            ssize_t n = pread(vdev->vbasedev.fd, buf, op->size, op->offset);
+            if (n == (ssize_t)op->size) {
+                g_autofree char *path = g_strdup_printf(
+                    "/run/hypervisor/kvm/%s/igd-opregion.bin", vm_name);
+                FILE *f = fopen(path, "wb");
+                if (f) {
+                    if (fwrite(buf, 1, op->size, f) == op->size) {
+                        const unsigned char *p = buf;
+                        error_report("IGD: OpRegion dumped to %s "
+                                     "(%u bytes, magic=\"%c%c%c%c%c%c%c%c"
+                                     "%c%c%c%c%c%c%c%c\")",
+                                     path, (unsigned)op->size,
+                                     p[0], p[1], p[2], p[3], p[4], p[5],
+                                     p[6], p[7], p[8], p[9], p[10], p[11],
+                                     p[12], p[13], p[14], p[15]);
+                    } else {
+                        error_report("IGD: OpRegion fwrite to %s failed",
+                                     path);
+                    }
+                    fclose(f);
+                } else {
+                    error_report("IGD: OpRegion fopen %s: %s",
+                                 path, strerror(errno));
+                }
+            } else {
+                error_report("IGD: OpRegion pread short read: %zd of %u",
+                             n, (unsigned)op->size);
+            }
+        } else {
+            error_report("IGD: OpRegion region not available "
+                         "(vm_name=%s)", vm_name ? vm_name : "<null>");
+        }
+    }
+
     /*
      * BDSM is read-write, emulated.  Initialize to 0 here (before the BDF
      * and LPC bridge checks) so that:
