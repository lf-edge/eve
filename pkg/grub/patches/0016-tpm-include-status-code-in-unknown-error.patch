From a291126047842052d3a119340ef2c92d4954ca12 Mon Sep 17 00:00:00 2001
From: Mikhail Malyshev <mike.malyshev@gmail.com>
Date: Fri, 27 Mar 2026 10:54:36 +0000
Subject: [PATCH] tpm: include EFI status code in "unknown TPM error" message

When grub encounters an EFI status code that doesn't match any of the
known TPM error cases, it currently prints the unhelpful generic
"Unknown TPM error" message, making it impossible to diagnose the
root cause (e.g. after a hardware watchdog reset).

Include the raw EFI status value (hex) so that the actual code is
visible in the GRUB output and logs.

Signed-off-by: Mikhail Malyshev <mike.malyshev@gmail.com>
---
 grub-core/kern/efi/tpm.c | 12 ++++++++----
 1 file changed, 8 insertions(+), 4 deletions(-)

diff --git a/grub-core/kern/efi/tpm.c b/grub-core/kern/efi/tpm.c
index e10054e31..4a5f82b35 100644
--- a/grub-core/kern/efi/tpm.c
+++ b/grub-core/kern/efi/tpm.c
@@ -102,7 +102,8 @@ grub_tpm1_execute(grub_efi_handle_t tpm_handle,
   case GRUB_EFI_NOT_FOUND:
     return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("TPM unavailable"));
   default:
-    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("Unknown TPM error"));
+    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, "Unknown TPM error: 0x%lx",
+		       (unsigned long) status);
   }
 }
 
@@ -139,7 +140,8 @@ grub_tpm2_execute(grub_efi_handle_t tpm_handle,
   case GRUB_EFI_NOT_FOUND:
     return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("TPM unavailable"));
   default:
-    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("Unknown TPM error"));
+    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, "Unknown TPM error: 0x%lx",
+		       (unsigned long) status);
   }
 }
 
@@ -214,7 +216,8 @@ grub_tpm1_log_event(grub_efi_handle_t tpm_handle, unsigned char *buf,
   case GRUB_EFI_NOT_FOUND:
     return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("TPM unavailable"));
   default:
-    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("Unknown TPM error"));
+    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, "Unknown TPM error: 0x%lx",
+		       (unsigned long) status);
   }
 }
 
@@ -260,7 +263,8 @@ grub_tpm2_log_event(grub_efi_handle_t tpm_handle, unsigned char *buf,
   case GRUB_EFI_NOT_FOUND:
     return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("TPM unavailable"));
   default:
-    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, N_("Unknown TPM error"));
+    return grub_error (GRUB_ERR_UNKNOWN_DEVICE, "Unknown TPM error: 0x%lx",
+		       (unsigned long) status);
   }
 }
 
