Date: Fri, 19 Jun 2026 14:38:18 +0200
Subject: [PATCH 15/21] Add EVE-OS boot logo
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Replace u-boot with EVE-OS 640x480 BMP logo

Signed-off-by: Renê de Souza Pinto <rene@renesp.com.br>
---
 configs/rpi_arm64_defconfig   |   7 +++++++
 drivers/video/u_boot_logo.bmp | Bin 6932 -> 23496 bytes
 drivers/video/video-uclass.c  |   4 +++-
 3 files changed, 10 insertions(+), 1 deletion(-)

diff --git a/configs/rpi_arm64_defconfig b/configs/rpi_arm64_defconfig
index cfe7527441f..d55be07a944 100644
--- a/configs/rpi_arm64_defconfig
+++ b/configs/rpi_arm64_defconfig
@@ -71,11 +71,18 @@ CONFIG_USB_HOST_ETHER=y
 CONFIG_USB_ETHER_LAN78XX=y
 CONFIG_USB_ETHER_SMSC95XX=y
 CONFIG_VIDEO=y
+CONFIG_VIDEO_LOGO=y
 # CONFIG_VIDEO_BPP8 is not set
 # CONFIG_VIDEO_BPP16 is not set
 CONFIG_SYS_WHITE_ON_BLACK=y
 CONFIG_VIDEO_BCM2835=y
 CONFIG_CONSOLE_SCROLL_LINES=10
+CONFIG_VIDEO_DT_SIMPLEFB=y
+CONFIG_BMP=y
+CONFIG_VIDEO_BMP_GZIP=y
+CONFIG_BMP_16BPP=y
+CONFIG_BMP_24BPP=y
+CONFIG_BMP_32BPP=y
 CONFIG_PHYS_TO_BUS=y
 CONFIG_TPM=y
 # CONFIG_HEXDUMP is not set
diff --git a/drivers/video/u_boot_logo.bmp b/drivers/video/u_boot_logo.bmp
index 47f1e9b99789584d2f6dd71e954b51927b35d783..0081ffd944aac21410ccf81ca2ea176a74dde39c 100644
