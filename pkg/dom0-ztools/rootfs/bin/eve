#!/bin/sh

CTR_CMD="ctr --namespace services.linuxkit"
CTR_UA_CMD="ctr --namespace eve-user-apps"
KVM_RUN_DIR="/run/hypervisor/kvm"
APP_CONFIG_DIR="/run/zedagent/AppInstanceConfig"
APP_STATUS_DIR="/run/zedmanager/AppInstanceStatus"
SERVICE_OVERRIDE_DIR="/run/eve-service-overrides"

# Locate jq: use the binary shipped inside the pillar onboot container.
# The binary needs libonig from the same sysroot, so we set LD_LIBRARY_PATH.
_JQ_SYSROOT="/containers/onboot/004-pillar-onboot/lower"
jq() { LD_LIBRARY_PATH="${_JQ_SYSROOT}/usr/lib" "${_JQ_SYSROOT}/usr/bin/jq" "$@"; }

help() {
  cat <<__EOT__
Welcome to EVE!
  commands: app list                List user applications with display names
            app enter <app>         Enter user app (real shell for NOHYPE containers;
                                    containerd-shim context for VM/shim-VM apps —
                                    use 'app console' for VM interactive access)
            app console             List available app consoles
            app console <console>   Attach to an application console
            enter [service] [command (assumed sh)]
            exec [--fork] [service] command
            list
            status
            start <service>
            pause <service>
            resume <service>
            destroy <service>
            list-app-consoles   Outputs list of available consoles for attach
            attach-app-console <console id>   Attach to the application console, see 'eve list-app-consoles' for details
            ext-start <service>   Start an extension service
            ext-stop <service>    Pause an extension service
            ext-list              List extension services and status
            persist list
            persist attach <disk>
            config mount <mountpoint>
            config unmount
            remote-access on|off
            http-debug
            dump-stacks
            dump-memory
            memory-monitor-update-config
            psi-collector start|stop
            firewall drop
            verbose on|off
            version
            uuid
            hv

  deprecated aliases (kept for backward compatibility):
            enter-user-app <app>           Same as 'app enter <app>'
            list-app-consoles              Same as 'app console'
            attach-app-console <console>   Same as 'app console <console>'
__EOT__
  exit 1
}

sec_start=2048
sec_end=0
num_p3_part=9
p3_old_tag=P3_OLD

list_partitions() {
  p3_dev=$(/sbin/findfs PARTLABEL=P3)
  p3_dev_base=$(basename "$p3_dev")
  /bin/lsblk -o KNAME,TYPE,SIZE,MODEL,PARTLABEL
  echo "CURRENT PERSIST PARTITION IS: $p3_dev_base"
}

relabel_dev() {
  /usr/bin/sgdisk -c "$num_p3_part":"$1" "$2"
}

clear_gpt() {
  /usr/bin/sgdisk -g --clear "$1"
}

create_new_p3_part() {
  /usr/bin/sgdisk --new "$num_p3_part":"$sec_start":"$sec_end" \
                  --typecode="$num_p3_part":7dcc9ef1-b744-454a-b6ee-c15af7e3eea9 \
                  --change-name="$num_p3_part":'P3' "$1"
}

mount_partlabel() {
  PARTLABEL="$1"
  if [ -z "$2" ]; then
    echo "ERROR: no mountpoint provided" && help
  fi
  MOUNTPOINT="$2"
  if ! mkdir -p "$MOUNTPOINT"; then
     echo "ERROR: failed to ensure $MOUNTPOINT" && exit 1
  fi
  MOUNT_DEV=$(/sbin/findfs PARTLABEL="$PARTLABEL")
  if [ -z "$MOUNT_DEV" ]; then
    echo "ERROR: no device with PARTLABEL=$PARTLABEL found" && exit 1
  fi
  if ! mount -t vfat -o rw,iocharset=iso8859-1 "$MOUNT_DEV" "$MOUNTPOINT"; then
     echo "ERROR: mount $MOUNT_DEV on $MOUNTPOINT failed" && exit 1
  fi
}

unmount_partlabel() {
  PARTLABEL="$1"
  MOUNT_DEV=$(/sbin/findfs PARTLABEL="$PARTLABEL")
  if [ -z "$MOUNT_DEV" ]; then
    echo "ERROR: no device with PARTLABEL=$PARTLABEL found" && exit 1
  fi
  if ! umount "$MOUNT_DEV"; then
     echo "ERROR: umount $MOUNT_DEV failed" && exit 1
  fi
}

http_debug_request() {
    URL="$1"
    running=0

    if nc -z 127.1 6543; then
        running=1
    fi

    if [ "$running" = "0" ]; then
        kill -USR2 "$(cat /run/zedbox.pid)"
    fi

    printf "POST %s HTTP/1.0\r\n\r\n" "$URL" | nc 127.1 6543

    if [ "$running" = "0" ]; then
        printf "POST /stop HTTP/1.0\r\n\r\n" | nc 127.1 6543
    fi
}

dump_stacks() {
    http_debug_request "/dump/stacks"
}

dump_mem() {
    http_debug_request "/dump/memory"
}

psi_collector_start() {
    http_debug_request "/memory-monitor/psi-collector/start"
}

psi_collector_stop() {
    http_debug_request "/memory-monitor/psi-collector/stop"
}

is_extension_service() {
    [ -d "/persist/exts/containers/services/$1" ]
}

set_service_override() {
    mkdir -p "$SERVICE_OVERRIDE_DIR" || return 1
    printf "%s\n" "$2" > "$SERVICE_OVERRIDE_DIR/$1"
}

clear_service_override() {
    rm -f "$SERVICE_OVERRIDE_DIR/$1"
}

service_task_status() {
    ${CTR_CMD} t ls 2>/dev/null | awk -v svc="$1" '$1 == svc {print $3; exit}'
}

is_in_debug_service() {
    grep -q '/eve/services/debug' < /proc/self/cgroup
}

# --- App subcommand functions ---

# VmMode values (from pkg/pillar/types/domainmgrtypes.go, iota+0)
VMMODE_NOHYPER=4

# Map VmMode numeric value to a human-readable string.
vmmode_to_string() {
    case "$1" in
        0) echo "PV" ;;
        1) echo "HVM" ;;
        3) echo "FML" ;;
        4) echo "NOHYPE" ;;
        5) echo "LEGACY" ;;
        *) echo "?" ;;
    esac
}

# Determine app type string: "VM(<mode>)" or "CONTAINER(<mode>)"
# by checking whether the boot image is a container image (ContentFormat==8)
# or a VM disk image.  ContentFormat comes from VolumeRefStatusList in
# AppInstanceStatus; VirtualizationMode comes from AppInstanceConfig.
#   ContentFormat 8 = Format_CONTAINER (see eve-api config/storage.pb.go)
# Usage: app_type_string <cfg_file> <status_file>
app_type_string() {
    _cfg="$1"
    _sts="$2"
    _vmode=$(jq -r '.FixedResources.VirtualizationMode // 0' "$_cfg" 2>/dev/null)
    _vmode_str=$(vmmode_to_string "$_vmode")
    # Check if any volume has ContentFormat==8 (CONTAINER)
    _is_container=""
    if [ -f "$_sts" ]; then
        _is_container=$(jq -r \
            '[.VolumeRefStatusList[]? | .ContentFormat] | if any(. == 8) then "yes" else "" end' \
            "$_sts" 2>/dev/null)
    fi
    if [ "$_is_container" = "yes" ]; then
        echo "CONTAINER(${_vmode_str})"
    else
        echo "VM(${_vmode_str})"
    fi
}

# Map SwState numeric value (from pkg/pillar/types/types.go) to a
# human-readable string.  The enum starts at iota+100.
swstate_to_string() {
    case "$1" in
        100) echo "INITIAL" ;;
        101) echo "RESOLVING_TAG" ;;
        102) echo "RESOLVED_TAG" ;;
        103) echo "DOWNLOADING" ;;
        104) echo "DOWNLOADED" ;;
        105) echo "VERIFYING" ;;
        106) echo "VERIFIED" ;;
        107) echo "LOADING" ;;
        108) echo "LOADED" ;;
        109) echo "CREATING_VOLUME" ;;
        110) echo "CREATED_VOLUME" ;;
        111) echo "INSTALLED" ;;
        112) echo "AWAITNETWORKINSTANCE" ;;
        113) echo "START_DELAYED" ;;
        114) echo "BOOTING" ;;
        115) echo "RUNNING" ;;
        116) echo "PAUSING" ;;
        117) echo "PAUSED" ;;
        118) echo "HALTING" ;;
        119) echo "HALTED" ;;
        120) echo "BROKEN" ;;
        121) echo "UNKNOWN" ;;
        122) echo "PENDING" ;;
        123) echo "SCHEDULING" ;;
        124) echo "FAILED" ;;
          *) echo "UNKNOWN($1)" ;;
    esac
}

app_list() {
    printf "%-20s %-38s %-18s %s\n" "DISPLAY NAME" "APP UUID" "TYPE" "STATUS"
    printf "%-20s %-38s %-18s %s\n" "------------" "--------" "----" "------"
    for _cfg in "${APP_CONFIG_DIR}"/*.json; do
        [ -f "$_cfg" ] || continue
        _uuid=$(basename "$_cfg" .json)
        _dname=$(json_field "$_cfg" DisplayName)
        [ -z "$_dname" ] && _dname="-"
        _state_str="UNKNOWN"
        _status_file="${APP_STATUS_DIR}/${_uuid}.json"
        if [ -f "$_status_file" ]; then
            _state_num=$(json_field "$_status_file" State)
            _state_str=$(swstate_to_string "$_state_num")
        fi
        _type_str=$(app_type_string "$_cfg" "$_status_file")
        printf "%-20s %-38s %-18s %s\n" "$_dname" "$_uuid" "$_type_str" "$_state_str"
    done
}

app_enter() {
    [ -z "$1" ] && help
    RESOLVED=$(resolve_user_app "$1")
    _rc=$?
    if [ "$_rc" -eq 2 ]; then
        echo "ERROR: app '$1' is halted (no running container)."
        echo "Use 'eve app list' to see app status."
        exit 1
    elif [ -z "$RESOLVED" ]; then
        echo "ERROR: no user app matching '$1' found."
        echo "Use 'eve app list' to see available apps."
        exit 1
    fi
    # Warn if this is not a native (NOHYPE) container
    _enter_uuid=$(get_uuid_from_container_id "$RESOLVED")
    _cfg_file="${APP_CONFIG_DIR}/${_enter_uuid}.json"
    _sts_file="${APP_STATUS_DIR}/${_enter_uuid}.json"
    if [ -f "$_cfg_file" ]; then
        _vmode=$(jq -r '.FixedResources.VirtualizationMode // 0' "$_cfg_file" 2>/dev/null)
        if [ "$_vmode" != "$VMMODE_NOHYPER" ]; then
            _type_str=$(app_type_string "$_cfg_file" "$_sts_file")
            echo "WARNING: this app is ${_type_str}, not a native container."
            echo "You are entering the containerd-shim context, not the application itself."
            echo "Use 'eve app console <console-id>' for interactive VM access."
            echo ""
        fi
    fi
    _shell=$(${CTR_UA_CMD} c info "${RESOLVED}" 2>/dev/null \
        | jq -r '.Spec.process.env[] | select(startswith("SHELL=")) | sub("SHELL=";"")' 2>/dev/null)
    if [ -z "$_shell" ]; then
        if ${CTR_UA_CMD} t exec --exec-id "_probe_$$" "${RESOLVED}" /bin/bash -c "exit 0" >/dev/null 2>&1; then
            _shell=/bin/bash
        else
            _shell=/bin/sh
        fi
    fi
    # shellcheck disable=SC2046,SC2086
    ${CTR_UA_CMD} t exec -t --exec-id $(basename $(mktemp)) ${RESOLVED} ${_shell} -l
}

app_console_list() {
    if ! is_in_debug_service; then
        eve enter debug "eve app console"
        exit
    fi
    printf "PID\tAPP-UUID\t\t\t\tCONS-TYPE\tCONS-ID\n"
    # shellcheck disable=SC3045
    printf "---\t--------\t\t\t\t---------\t---------\n"
    for pid in $(pgrep qemu-system); do
        # shellcheck disable=SC2009
        name=$(ps -p "$pid" --no-headers -o command | grep -o '\-name\s\+[^ ]\+' | awk '{print $2}')
        # shellcheck disable=SC2009
        uuid=$(ps -p "$pid" --no-headers -o command | grep -o '\-uuid\s\+[^ ]\+' | awk '{print $2}')
        dir="$KVM_RUN_DIR/$name"
        if [ -e "$dir/shim-cons" ]; then
            printf "%s\t%s\tCONTAINER\t%s/cons\n" "$pid" "$uuid" "$name"
            printf "%s\t%s\tVM\t\t%s/shim-cons\n" "$pid" "$uuid" "$name"
        else
            printf "%s\t%s\tVM\t\t%s/cons\n" "$pid" "$uuid" "$name"
        fi
    done
}

app_console_attach() {
    if ! is_in_debug_service; then
        eve enter debug "eve app console $1"
        exit
    fi
    CONS="$KVM_RUN_DIR/$1"
    if [ ! -e "$CONS" ]; then
        echo "Error: console '$1' does not exist."
        echo "Try 'eve app console' to list available consoles."
        exit 1
    fi
    PTY=$(dirname "$CONS")/pty-$$
    trap 'kill $SOCAT_PID 2>/dev/null' EXIT HUP INT QUIT TERM
    socat "unix-connect:$CONS" "pty,link=$PTY" &
    SOCAT_PID=$!
    sleep 1
    tio "$PTY"
}

# Extract the app UUID from a container ID (strip trailing .N.M suffix)
get_uuid_from_container_id() {
    echo "$1" | sed 's/\.[0-9]*\.[0-9]*$//'
}

# Read a top-level string field from a JSON file.
# Usage: json_field <file> <field>
json_field() {
    jq -r ".$2 // empty" "$1" 2>/dev/null
}

# Look up the DisplayName for a given app UUID from AppInstanceConfig.
# Falls back to AppInstanceStatus under /run/zedmanager if needed.
get_app_display_name() {
    _uuid="$1"
    _name=""
    if [ -f "${APP_CONFIG_DIR}/${_uuid}.json" ]; then
        _name=$(json_field "${APP_CONFIG_DIR}/${_uuid}.json" DisplayName)
    fi
    if [ -z "$_name" ] && [ -f "${APP_STATUS_DIR}/${_uuid}.json" ]; then
        _name=$(json_field "${APP_STATUS_DIR}/${_uuid}.json" DisplayName)
    fi
    echo "$_name"
}

# Resolve a user-friendly display name to a container ID.
# If the argument already matches a container ID, return it as-is.
# Otherwise search AppInstanceConfig for a matching DisplayName,
# then pick the container that has a running task (preferred)
# or the first matching container.
resolve_user_app() {
    _arg="$1"
    # Check if argument is already a valid container ID
    if ${CTR_UA_CMD} c ls -q 2>/dev/null | grep -qx "$_arg"; then
        echo "$_arg"
        return 0
    fi
    # Treat as display name: find the UUID whose DisplayName matches
    _match_uuid=""
    for _cfg in "${APP_CONFIG_DIR}"/*.json; do
        [ -f "$_cfg" ] || continue
        _cfg_name=$(json_field "$_cfg" DisplayName)
        if [ "$_cfg_name" = "$_arg" ]; then
            _match_uuid=$(basename "$_cfg" .json)
            break
        fi
    done
    if [ -z "$_match_uuid" ]; then
        echo ""
        return 1  # not found
    fi
    # Find containers belonging to this UUID; prefer one with a running task
    _running=""
    _first=""
    for _cid in $(${CTR_UA_CMD} c ls -q 2>/dev/null); do
        _cid_uuid=$(get_uuid_from_container_id "$_cid")
        if [ "$_cid_uuid" = "$_match_uuid" ]; then
            [ -z "$_first" ] && _first="$_cid"
            if ${CTR_UA_CMD} t ls 2>/dev/null | grep -q "^${_cid} "; then
                _running="$_cid"
                break
            fi
        fi
    done
    if [ -n "$_running" ]; then
        echo "$_running"
        return 0
    elif [ -n "$_first" ]; then
        echo "$_first"
        return 0
    fi
    echo ""
    return 2  # found but no container (halted)
}

case "$1" in
    exec) NO_FORK="-F"
          if [ "$2" = "--fork" ]; then
            NO_FORK=""
            shift
          fi
          # shellcheck disable=SC2086
          ID=$(${CTR_CMD} t ls | awk '/^'${2:-pillar}' /{print $2;}' 2>/dev/null)
          CMD="${3:-sh}"
          shift ; shift ; shift
          for c in /sys/fs/cgroup/*/tasks; do echo "$$" >> "$c"; done
          # shellcheck disable=SC2086
          exec nsenter ${NO_FORK} -a -t "${ID:-1}" "$CMD" "$@"
          ;;
     app) case "$2" in
            list)    app_list ;;
            enter)   app_enter "$3" ;;
            console) if [ -z "$3" ]; then app_console_list; else app_console_attach "$3"; fi ;;
            *)       help ;;
          esac
          ;;
   enter) PROMPT="[${2:-pillar}] \u@\h:\w\$ "
          # shellcheck disable=SC2086
          ${CTR_CMD} t exec -t --exec-id $(basename $(mktemp)) ${2:-pillar} ${3:-/bin/sh -lc "export PS1='$PROMPT'; exec /bin/sh"}
          ;;
    list) ${CTR_CMD} c ls
          ;;
  status) ${CTR_CMD} t ls
          ;;
   start) [ -z "$2" ] && help
          if is_extension_service "$2"; then
              exec "$0" ext-start "$2"
          fi
          ${CTR_CMD} c ls -q | grep -Fxq "$2" && echo "ERROR: make sure to run: $0 destroy $2" && help
          /usr/bin/service -v start $2
          ;;
 destroy) [ -z "$2" ] && help
          if is_extension_service "$2"; then
              clear_service_override "$2"
          fi
          ${CTR_CMD} t kill -a -s SIGKILL $2
          ${CTR_CMD} t delete $2
          ${CTR_CMD} c rm $2
          ;;
   pause) [ -z "$2" ] && help
          if is_extension_service "$2"; then
              set_service_override "$2" disabled || {
                  echo "ERROR: failed to write local override for $2"
                  exit 1
              }
          fi
          ${CTR_CMD} t pause $2
          ;;
  resume) [ -z "$2" ] && help
          if is_extension_service "$2"; then
              set_service_override "$2" enabled || {
                  echo "ERROR: failed to write local override for $2"
                  exit 1
              }
          fi
          ${CTR_CMD} t resume $2
          ;;
firewall) if [ "$2" = drop ]; then
             nsenter -a -t "$(${CTR_CMD} t ls | awk '/^pillar /{print $2;}' 2>/dev/null)" sh -x <<__EOT__
               iptables -P INPUT ACCEPT
               iptables -P FORWARD ACCEPT
               iptables -P OUTPUT ACCEPT
               iptables -F
               iptables -X
               iptables -Z
               iptables -t nat -F
               iptables -t nat -X
               iptables -t mangle -F
               iptables -t mangle -X
               iptables -t raw -F
               iptables -t raw -X
__EOT__
          else
             help
          fi
          ;;
 http-debug) if [ -z "$2" ] || [ "$2" = "start" ]; then
              kill -USR2 "$(cat /run/zedbox.pid)"
              echo "Listening on :6543 -- use 'eve http-debug stop' to stop"
          elif [ "$2" = "stop" ]; then
              printf "POST /stop HTTP/1.0\r\n\r\n" | nc 127.1 6543
          else
              echo "Unknown command; use 'start' or 'stop'"
          fi
          ;;
 dump-stacks)
          dump_stacks
          echo "Your information can be found in logread"
          ;;
 dump-memory)
          dump_mem
          echo "Your information can be found in logread"
          ;;
 memory-monitor-update-config)
          pkill -SIGHUP -o memory-monitor
          echo "Updated memory-monitor configuration"
          ;;
 psi-collector)
          case "$2" in
            start)
              echo "Sending request to start PSI collector..."
              echo "If it succeeds, you will see the output in /persist/memory-monitor/output/psi.txt"
              psi_collector_start
                   ;;
            stop)
              echo "If collector was running, it should be stopped now and the output is in /persist/memory-monitor/output/psi.txt"
              psi_collector_stop
                   ;;
            *) help
               ;;
          esac
          ;;
 verbose) # first lets find our piping process
          PIPE=""
          while [ "$PIPE" = "" ]
          do
              for pid in $(pgrep cat)
              do
                 if [ "$(readlink /proc/"$pid"/fd/0)" = /run/diag.pipe ]
                 then
                     PIPE="$pid"
                 fi
              done
              if [ -z "$PIPE" ]
              then
                  sleep 1
              fi
          done
          # now lets see what to do with it
          case "$2" in
             on) dmesg -n8
                 kill -CONT "$PIPE"
                 ;;
            off) dmesg -n1
                 kill -STOP "$PIPE"
                 ;;
              *) help
                 ;;
          esac
          ;;
 remote-access)
          CONFIGDIR_RW="/tmp/config_rw"
          mkdir $CONFIGDIR_RW
          if eval "$(mount_partlabel "CONFIG" $CONFIGDIR_RW)"; then
              case "$2" in
                on) rm -f $CONFIGDIR_RW/remote_access_disabled
                    eval "$(unmount_partlabel "CONFIG")" && rm -rf $CONFIGDIR_RW
                    echo "Remote access enabled. Please reboot to apply changes."
                    ;;
                off) touch $CONFIGDIR_RW/remote_access_disabled
                     eval "$(unmount_partlabel "CONFIG")" && rm -rf $CONFIGDIR_RW
                     echo "Remote access disabled. Please reboot to apply changes."
                     ;;
                *) eval "$(unmount_partlabel "CONFIG")" && rm -rf $CONFIGDIR_RW
                   help
                   ;;
              esac
          else
              echo "Failed to set the remote access configuration!"
          fi
          ;;
 version)
          v=$(cat /run/eve-release)
          echo "$v"
          ;;
 uuid)
          uuid=$(cat /persist/status/uuid)
          echo "$uuid"
          ;;
 hv)
          type=$(cat /run/eve-hv-type)
          echo "$type"
          ;;
 ext-start) [ -z "$2" ] && echo "Usage: eve ext-start <service>" && help
          SVC="$2"
          SVC_PATH="/persist/exts/containers/services/$SVC"
          if [ ! -d "$SVC_PATH" ]; then
              echo "ERROR: extension service '$SVC' not found in $SVC_PATH"
              exit 1
          fi
          set_service_override "$SVC" enabled || {
              echo "ERROR: failed to write local override for $SVC"
              exit 1
          }
          STATUS=$(service_task_status "$SVC")
          case "$STATUS" in
              RUNNING)
                  echo "$SVC is already running"
                  ;;
              PAUSED)
                  echo "Resuming $SVC..."
                  ${CTR_CMD} t resume "$SVC" && echo "$SVC resumed"
                  ;;
              "")
                  echo "Local override enabled for $SVC."
                  echo "If the task is not present, extsloader will reconcile it on the next scan cycle (~30s)."
                  ;;
              *)
                  echo "Local override enabled for $SVC (current task state: $STATUS)."
                  echo "extsloader will reconcile it on the next scan cycle (~30s) if needed."
                  ;;
          esac
          ;;
 ext-stop) [ -z "$2" ] && echo "Usage: eve ext-stop <service>" && help
          SVC="$2"
          set_service_override "$SVC" disabled || {
              echo "ERROR: failed to write local override for $SVC"
              exit 1
          }
          STATUS=$(service_task_status "$SVC")
          if [ -z "$STATUS" ]; then
              echo "$SVC is not running (local override disabled)"
              exit 0
          fi
          if [ "$STATUS" = "PAUSED" ]; then
              echo "$SVC is already paused (local override disabled)"
              exit 0
          fi
          echo "Pausing $SVC..."
          ${CTR_CMD} t pause "$SVC"
          echo "$SVC paused"
          ;;
 ext-list) echo "Extension services:"
          for d in /persist/exts/containers/services/*/; do
              SVC=$(basename "$d")
              STATUS="stopped"
              if ${CTR_CMD} t ls 2>/dev/null | grep -q "^${SVC} .*RUNNING"; then
                  STATUS="running"
              elif ${CTR_CMD} t ls 2>/dev/null | grep -q "^${SVC} .*PAUSED"; then
                  STATUS="paused"
              fi
              printf "  %-20s %s\n" "$SVC" "$STATUS"
          done
          ;;
 persist) case "$2" in
               list) list_partitions
                     ;;
             attach) [ -z "$3" ] && help
                     shift 2
                     #fetch current P3 partition
                     curr_p3_dev=$(/sbin/findfs PARTLABEL=P3)
                     [ -z "$curr_p3_dev" ] && echo "Failed to find current P3 device" && exit 1
                     curr_p3_dsk="/dev/"$(lsblk -no pkname "$curr_p3_dev")

                     #Attach must be idempotent
                     [ "$curr_p3_dsk" = "$1" ] && echo "Persist is already on the given disk. Nothing to be done." && exit 0

                     #Clear GPT on new device, and create P3 partition
                     clear_gpt "$1"
                     create_new_p3_part "$1"

                     #check the result. At this point we should have two P3 partitions.
                     #since findfs returns only the first P3, use cgpt to be more specific
                     new_p3_dev=$(/usr/bin/cgpt find -l P3 "$1")
                     new_p3_dsk="/dev/"$(lsblk -no pkname "$new_p3_dev")
                     [ "$new_p3_dsk" != "$1" ] && echo "Failed to attach persist to $1" && exit 1

                     #now rename current partition label
                     echo "Removing P3 label from the old partition $curr_p3_dev"
                     relabel_dev "$p3_old_tag" "$curr_p3_dsk"

                     echo "Done. Attached persist to $1"
                     #print the partition
                     list_partitions
                     ;;
                  *) help
                     ;;
          esac
          ;;
 config) case "$2" in
               mount) mount_partlabel "CONFIG" "$3"
                     ;;
               unmount) unmount_partlabel "CONFIG"
                     ;;
               *) help
                     ;;
          esac
          ;;
 # Backward-compatible aliases for deprecated commands
 list-app-consoles)
          app_console_list
          ;;
 attach-app-console)
          [ -z "$2" ] && help
          app_console_attach "$2"
          ;;
 enter-user-app)
          [ -z "$2" ] && help
          app_enter "$2"
          ;;
       *) help
          ;;
esac
